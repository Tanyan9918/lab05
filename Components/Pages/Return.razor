@page "/return"
@using lab05.Services
@using lab05.Models
@inject ILibraryService library

<h3>Return Book</h3>



<select @bind="selectedUserId" @bind:after="OnUserChanged" class="form-select mb-3">
    <option value="0">Select User</option>
    @foreach (var user in library.Users)
    {
        <option value="@user.Id">@user.Name</option>
    }
</select>

@if (userBorrowedBooks?.Any() == true)
{
    <ul class="list-group">
        @for (int i = 0; i < userBorrowedBooks.Count; i++)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                @userBorrowedBooks[i].Title by @userBorrowedBooks[i].Author
                <button class="btn btn-warning btn-sm" @onclick="() => ReturnBook(i)">Return</button>
            </li>
        }
    </ul>
}

<p class="mt-3">@message</p>

@code {
    private int selectedUserId;
    private List<Books> userBorrowedBooks = new List<Books>();
    private string message;

    private void LoadBorrowedBooks(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int userId))
        {
            selectedUserId = userId;
            userBorrowedBooks = library.GetUserBorrowedBooks(selectedUserId);
        }
        else
        {
            userBorrowedBooks = new List<Books>();
        }
    }


    private void ReturnBook(int bookIndex)
    {

        message = library.ReturnBook(selectedUserId, bookIndex);
        userBorrowedBooks = library.GetUserBorrowedBooks(selectedUserId);
    }

    private void OnUserChanged()
    {
        if (selectedUserId != 0)
        {
            userBorrowedBooks = library.GetUserBorrowedBooks(selectedUserId);
        }
        else
        {
            userBorrowedBooks = new List<Books>();
        }
    }
}
